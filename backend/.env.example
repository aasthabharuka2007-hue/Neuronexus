# Copy to .env and fill in values

# News (required)
NEWS_API_KEY=your_newsapi_org_key

# AI — set at least one of GEMINI_API_KEY or OPENAI_API_KEY
# Recommended: Gemini free tier — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# auto | gemini | openai  (auto prefers Gemini when GEMINI_API_KEY is set)
AI_PROVIDER=auto

# Optional: OpenAI for TTS (MP3), Whisper, or set AI_PROVIDER=openai for GPT-only
OPENAI_API_KEY=

# Optional
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
MAX_UPLOAD_MB=50
CACHE_TTL_SECONDS=300
DATABASE_URL=sqlite+aiosqlite:///./voice_news.db
